"use client";

import { useRouter } from "next/navigation";

export default function ExperiencesPage() {
  const router = useRouter();

  const goCheckout = (name: string, price: number) => {
    router.push(
      `/checkout?name=${encodeURIComponent(name)}&price=${price}`
    );
  };

  return (
    <main style={{ padding: "2rem" }}>
      <h1>🌄 Experiencias Bike</h1>

      <button onClick={() => goCheckout("Tour Gravel Italia", 1200)}>
        Tour Gravel Italia
      </button>

      <button onClick={() => goCheckout("Training Camp Alpes", 1800)}>
        Training Camp Alpes
      </button>

      <button onClick={() => goCheckout("Weekend Santiago Ride", 300)}>
        Weekend Santiago Ride
      </button>
    </main>
  );
}